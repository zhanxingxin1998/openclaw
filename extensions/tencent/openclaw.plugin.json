    "discovery": {
      "tencent-tokenhub": "static",
      "tencent-tokenplan": "static"
    }
  },
  "setup": {
    "providers": [
      {
        "id": "tencent-tokenhub",
        "envVars": ["TOKENHUB_API_KEY"]
