  "configContracts": {
    "compatibilityMigrationPaths": [
      "models.providers.tencent-tokenhub",
      "agents.defaults.models.tencent-tokenhub/hy3",
      "agents.defaults.models.tencent-tokenhub/hy3-preview"
    ]
  },
  "providerAuthChoices": [
